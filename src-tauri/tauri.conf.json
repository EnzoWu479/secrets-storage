{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Secrets Storage",
  "version": "0.1.4",
  "identifier": "dev.enzoyujiwu.secrets-storage",
  "build": {
    "beforeDevCommand": "vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "vue-tsc --noEmit && vite build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Secrets Storage",
        "width": 1024,
        "height": 720,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; img-src 'self' data:; style-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
