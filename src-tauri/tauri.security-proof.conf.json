{
  "$schema": "https://schema.tauri.app/config/2",
  "build": {
    "beforeDevCommand": "vite --config e2e/security-proof/vite.config.ts",
    "devUrl": "http://localhost:1422",
    "beforeBuildCommand": "vue-tsc --noEmit && vite build --config e2e/security-proof/vite.config.ts",
    "frontendDist": "../dist/security-proof"
  },
  "app": {
    "windows": [
      {
        "label": "security-proof",
        "title": "Secrets Storage Security Proof",
        "width": 900,
        "height": 680,
        "minWidth": 760,
        "minHeight": 560,
        "devtools": false
      }
    ],
    "security": {
      "capabilities": ["security-proof"]
    }
  },
  "bundle": {
    "active": false
  }
}
