{
  "name": "secrets-storage",
  "private": true,
  "version": "0.1.2",
  "packageManager": "pnpm@11.13.0",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "build": "tauri build",
    "tauri": "tauri",
    "test:frontend": "vitest run",
    "format:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml --check",
    "lint:rust": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets --all-features -- -D warnings",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "check:frontend": "pnpm test:frontend && vue-tsc --noEmit && vite build",
    "check:rust": "pnpm format:rust && pnpm lint:rust && pnpm test:rust",
    "check": "pnpm check:frontend && pnpm check:rust"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4",
    "@tauri-apps/cli": "^2",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.11",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vitest": "^4.1.10",
    "vue-tsc": "^2.1.10"
  }
}
