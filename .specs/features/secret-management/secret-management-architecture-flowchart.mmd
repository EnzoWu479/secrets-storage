%% Diagram: Arquitetura de gerenciamento de segredos | Date: 2026-07-19
%%{init: {'theme': 'base', 'themeVariables': {'primaryColor': '#4f46e5', 'primaryTextColor': '#334155', 'primaryBorderColor': '#3730a3', 'lineColor': '#94a3b8', 'secondaryColor': '#10b981', 'tertiaryColor': '#f59e0b', 'background': '#ffffff', 'mainBkg': '#f8fafc', 'nodeBorder': '#cbd5e1', 'clusterBkg': '#f1f5f9', 'clusterBorder': '#e2e8f0', 'titleColor': '#1e293b', 'edgeLabelBackground': '#ffffff', 'textColor': '#334155'}}}%%
flowchart TD
    subgraph webview["WebView não confiável"]
        direction LR
        screens["Telas Vue"]
        api["API tipada"]
        ephemeral["Estado efêmero<br/>de reveal"]
    end

    subgraph core["Core Rust confiável"]
        direction LR
        commands["Comandos Tauri<br/>allowlisted"]
        service["SecretService"]
        sessions["SessionManager<br/>lock + epoch"]
        codec["Codec tipado v1"]
        clipboard["ClipboardPort<br/>core-only"]
    end

    subgraph storage["Persistência local"]
        direction LR
        envelope["Envelope AEAD"]
        writer["AtomicVaultWriter"]
        vaults[(Vaults cifrados)]
    end

    screens -->|"invoca DTO limitado"| api
    api -->|"IPC com capability"| commands
    commands -->|"revalida label e input"| service
    service -->|"autoriza início e commit"| sessions
    sessions -->|"codifica payload"| codec
    codec -->|"cifra conteúdo"| envelope
    envelope -->|"temp + flush + replace"| writer
    writer --> vaults
    service -->|"copy sem devolver valor"| clipboard
    commands -->|"reveal explícito"| ephemeral

    classDef trusted fill:#4f46e5,color:#fff,stroke:#3730a3;
    classDef data fill:#10b981,color:#fff,stroke:#047857;
    classDef boundary fill:#f59e0b,color:#1f2937,stroke:#d97706;
    class commands,service,sessions,codec trusted;
    class envelope,writer,vaults data;
    class screens,api,ephemeral,clipboard boundary;
